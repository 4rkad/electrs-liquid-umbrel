+    /// Download all block headers and return compact entries (height, hash, time, prev_blockhash).
+    /// Full BlockHeaders are dropped after extracting compact data, keeping RAM usage low.
+    #[trace]
+    pub fn get_all_headers_compact(&self, tip: &BlockHash) -> Result<Vec<HeaderEntry>> {
+        let info: Value = self.request("getblockheader", json!([tip]))?;
+        let tip_height = info
+            .get("height")
+            .expect("missing height")
+            .as_u64()
+            .expect("non-numeric height") as usize;
+        let all_heights: Vec<usize> = (0..=tip_height).collect();
+        let chunk_size = 100_000;
+        let mut result: Vec<HeaderEntry> = Vec::with_capacity(tip_height + 1);
+        let mut expected_blockhash = *DEFAULT_BLOCKHASH;
+
+        for heights in all_heights.chunks(chunk_size) {
+            let headers = self.getblockheaders(&heights)?;
+            assert!(headers.len() == heights.len());
+
+            let base_height = result.len();
+            for (i, header) in headers.into_iter().enumerate() {
+                assert_eq!(header.prev_blockhash, expected_blockhash);
+                let hash = header.block_hash();
+                result.push(HeaderEntry::from_header(base_height + i, hash, &header));
+                expected_blockhash = hash;
+                // header is dropped here — no accumulation of full BlockHeaders
+            }
+
+            info!(
+                "downloaded {}/{} block headers ({:.0}%)",
+                result.len(),
+                tip_height,
+                result.len() as f32 / tip_height as f32 * 100.0
+            );
+        }
+
+        assert_eq!(expected_blockhash, *tip);
+        Ok(result)
+    }
